# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Neon Postgres (pgvector enabled)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Agents
GROQ_API_KEY=
OPENAI_API_KEY=

# Agent orchestration / observability (LangGraph + LangSmith)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=prism

# Auth (Clerk) — verifies the session token issued to the frontend
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Cache / rate-limit (Upstash Redis REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Shopify app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_WEBHOOK_SECRET=

# Stripe Connect
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Observability / ops
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BREVO_API_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Phase 2 — creator content ingestion (not required for MVP)
YOUTUBE_API_KEY=
